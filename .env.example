# Environment variables required for Netlify Functions
# Copy this file to .env for local development (never commit .env)
# Set all values in Netlify dashboard: Site settings → Environment variables
#
# Every variable here is required in production. A missing variable causes
# the relevant function to log a warning and skip that integration silently
# (see each function for the exact fallback behaviour).

# Slack incoming webhook URL
# Where to get it: Slack app settings → Your Apps → [app] → Incoming Webhooks
# Used by: netlify/functions/submission-created.js
#          netlify/functions/newsletter-subscribe.js
SLACK_WEBHOOK_URL=

# Brevo API key (transactional email + contact list management)
# Where to get it: app.brevo.com → Account → API Keys (SMTP & API tab)
# Used by: netlify/functions/newsletter-subscribe.js (adds contacts to list #9)
BREVO_API_KEY=

# Airtable personal access token
# Where to get it: airtable.com/create/tokens → Create token (scopes: data.records:write)
# Used by: netlify/functions/submission-created.js (CRM lead insert)
AIRTABLE_TOKEN=

# Airtable base ID for the CRM & Delivery base (format: appXXXXXXXXXXXXXX)
# Where to get it: open the base in Airtable → Help → API documentation → base ID in URL
# Used by: netlify/functions/submission-created.js
AIRTABLE_BASE_ID=

# Airtable table name for lead submissions (exact string, case-sensitive)
# Used by: netlify/functions/submission-created.js
AIRTABLE_TABLE=
