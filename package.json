{
  "name": "accelerator-x-website",
  "version": "1.0.0",
  "description": "This repo contains the public landing page for Accelerator X.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "npx serve .",
    "build:css": "tailwindcss -i ./scripts/tailwind.input.css -o ./assets/css/tailwind.generated.css --minify",
    "build:hero-media": "node scripts/build-hero-media.js",
    "process:hero-images": "bash scripts/process-hero-images.sh",
    "build": "npm run build:css && node scripts/build-footer.js && node scripts/build-testimonials.js && npm run build:hero-media && node scripts/build-hub.js",
    "test:site": "node scripts/test-site.js",
    "session-end": "node scripts/session-end.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andy-carroll/accelerator-x-website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/andy-carroll/accelerator-x-website/issues"
  },
  "homepage": "https://github.com/andy-carroll/accelerator-x-website#readme",
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^17.0.3"
  }
}
